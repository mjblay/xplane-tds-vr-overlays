ATTR_no_cull
ATTR_no_blend
ATTR_draw_enable
ATTR_diffuse_rgb 0.0 0.0 0.0

# TDS custom-device screen
ATTR_manip_device button TDSGTN750XI_U1 TDS_GTN750xi
ATTR_cockpit_device TDSGTN750XI_U1 3 0 1
TRIS 0 6

# Hidden dummy manipulators to satisfy Thranda_F33_vrconfig.txt matching.
# These are deliberately tiny and not meant for user interaction.
ATTR_draw_disable
ATTR_no_cockpit

ATTR_manip_drag_xy hand 500.000 500.000 -1.000 1.000 1.000 -1.000 sim/cockpit2/controls/yoke_roll_ratio sim/cockpit2/controls/yoke_pitch_ratio Pilot's yoke
TRIS 6 6

ATTR_manip_drag_xy hand 500.000 500.000 -1.000 1.000 1.000 -1.000 sim/cockpit2/controls/yoke_roll_ratio sim/cockpit2/controls/yoke_pitch_ratio Copilot's yoke
TRIS 12 6

ATTR_manip_drag_axis rotate_small 0.100 0.100 0.000 0.000 1.000 thranda/cockpit/ASIcalib
TRIS 18 6

ATTR_manip_drag_axis hand 0.000 0.040 0.000 -1.000 4.000 thranda/starter_key1
TRIS 24 6

ATTR_manip_drag_axis rotate_medium 0.100 0.100 0.000 0.000 2.000 thranda/cockpit/actuators/FuelSwL
TRIS 30 6

ATTR_manip_none

# XPTO PAE A36 dummy VRCONFIG compatibility manipulators
# These hidden stubs satisfy aircraft VRCONFIG validation
# when this clickable overlay OBJ is attached to the aircraft.
ATTR_draw_disable
ATTR_manip_drag_xy four_arrows 100.000 -100.000 -1.000 1.000 -1.000 1.000 sim/cockpit2/controls/yoke_roll_ratio_copilot sim/cockpit2/controls/yoke_pitch_ratio_copilot
TRIS 0 3
ATTR_manip_none

ATTR_manip_command_knob rotate_large sim/ignition/ignition_up_1 sim/ignition/ignition_down_1 Starter Switch
TRIS 0 3
ATTR_manip_none
ATTR_draw_enable


# XPTO magenta positioning border
ATTR_draw_enable
ATTR_no_cull
ATTR_no_blend
ATTR_diffuse_rgb 1.0 0.0 1.0
TRIS 36 24
ATTR_diffuse_rgb 0.0 0.0 0.0
